{
  "name": "prosource-crm-v2",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "description": "ProSource CRM for sourcing businesses",
  "author": "rahadsakib1234-boop",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite --host",
    "dev:electron": "concurrently -k \"vite --host\" \"wait-on http://localhost:5173 && electron -r tsx/cjs electron/main.ts\"",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:web": "vite build",
    "build:electron:main": "esbuild electron/main.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/electron/main.js",
    "build:electron:preload": "esbuild electron/preload.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/electron/preload.js",
    "build:electron": "pnpm run build:web && pnpm run build:electron:main && pnpm run build:electron:preload && electron-builder --config electron-builder.yml --win --x64 --publish never",
    "build:electron:arm64": "pnpm run build:web && pnpm run build:electron:main && pnpm run build:electron:preload && electron-builder --config electron-builder.yml --win --arm64 --publish never",
    "start": "electron dist/electron/main.js",
    "preview": "vite preview --host",
    "check": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
