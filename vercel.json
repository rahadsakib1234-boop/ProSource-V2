{
  "version": 3,
  "build": {
    "command": "pnpm run build",
    "outputDirectory": "dist/public",
    "environment": {
      "VITE_SUPABASE_URL": "@supabase_url",
      "VITE_SUPABASE_ANON_KEY": "@supabase_anon_key"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
