#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../@electron+windows-sign@1.2.2/node_modules/@electron/windows-sign/bin/electron-windows-sign.js" "$@"
else
  exec node  "$basedir/../../../../../@electron+windows-sign@1.2.2/node_modules/@electron/windows-sign/bin/electron-windows-sign.js" "$@"
fi
