#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../@electron+asar@3.4.1/node_modules/@electron/asar/bin/asar.js" "$@"
else
  exec node  "$basedir/../../../../../@electron+asar@3.4.1/node_modules/@electron/asar/bin/asar.js" "$@"
fi
