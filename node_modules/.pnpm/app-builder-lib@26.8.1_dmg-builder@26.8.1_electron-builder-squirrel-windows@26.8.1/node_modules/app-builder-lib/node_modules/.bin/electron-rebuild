fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../@electron+rebuild@4.0.4/node_modules/@electron/rebuild/lib/cli.js" "$@"
else
  exec node  "$basedir/../../../../../@electron+rebuild@4.0.4/node_modules/@electron/rebuild/lib/cli.js" "$@"
fi
