#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/workspaces/ProSource-V2/node_modules/.pnpm/wait-on@9.0.10/node_modules/wait-on/bin/node_modules:/workspaces/ProSource-V2/node_modules/.pnpm/wait-on@9.0.10/node_modules/wait-on/node_modules:/workspaces/ProSource-V2/node_modules/.pnpm/wait-on@9.0.10/node_modules:/workspaces/ProSource-V2/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/workspaces/ProSource-V2/node_modules/.pnpm/wait-on@9.0.10/node_modules/wait-on/bin/node_modules:/workspaces/ProSource-V2/node_modules/.pnpm/wait-on@9.0.10/node_modules/wait-on/node_modules:/workspaces/ProSource-V2/node_modules/.pnpm/wait-on@9.0.10/node_modules:/workspaces/ProSource-V2/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/wait-on@9.0.10/node_modules/wait-on/bin/wait-on" "$@"
else
  exec node  "$basedir/../.pnpm/wait-on@9.0.10/node_modules/wait-on/bin/wait-on" "$@"
fi
